<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#333333">

    <!-- MAPA (Fondo, visible solo al aceptar) -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/mapWorker"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="#99000000"> <!-- Fondo semitransparente para ver mapa -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modo Trabajador"
            android:textColor="#AAAAAA"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_centerVertical="true"/>

        <!-- Switch Estado -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/btnVolverUsuario"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:text="Offline"
            android:textColor="#AAAAAA"
            android:checked="false" />

        <!-- Icono para volver a modo usuario -->
        <ImageView
            android:id="@+id/btnVolverUsuario"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_trabajador"
            app:tint="#00BCD4" />

    </RelativeLayout>

    <!-- Título SOLICITUDES -->
    <TextView
        android:id="@+id/tvSolicitudes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerLayout"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:text="SOLICITUDES"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:shadowColor="#000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"/>

    <!-- Tarjeta de Solicitud -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardRequest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvSolicitudes"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="#4DD0E1"
        app:cardElevation="8dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Foto Avatar -->
            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_user"
                android:background="@drawable/bg_circle_white"
                android:padding="2dp"/>

            <!-- Nombre y Hora -->
            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/ivAvatar"
                android:layout_marginStart="12dp"
                android:text="CLIENTE"
                android:textStyle="bold"
                android:textColor="#000000"
                android:textSize="14sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Ahora"
                android:textStyle="bold"
                android:textColor="#000000"
                android:textSize="12sp"/>

            <!-- Descripción -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvName"
                android:layout_toEndOf="@id/ivAvatar"
                android:layout_marginStart="12dp"
                android:layout_marginTop="4dp"
                android:text="Detalle del servicio"
                android:textStyle="bold"
                android:textColor="#000000"
                android:textSize="14sp"/>

            <!-- Botón ACEPTAR -->
            <Button
                android:id="@+id/btnAceptarTrabajo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvDescription"
                android:layout_marginTop="16dp"
                android:text="ACEPTAR TRABAJO"
                android:backgroundTint="#2E7D32"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Botón LLEGUÉ (Nuevo) -->
            <Button
                android:id="@+id/btnLlegue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvDescription"
                android:layout_marginTop="16dp"
                android:text="📍 YA LLEGUÉ AL DOMICILIO"
                android:backgroundTint="#FF6200EE"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:visibility="gone" />

        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- Barra inferior de navegación -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="#DDDDDD"
        android:gravity="center"
        android:orientation="horizontal"
        android:elevation="8dp">

        <!-- Chat -->
        <ImageView
            android:id="@+id/navChat"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:src="@drawable/ic_chat_inicio"
            app:tint="#000000" />

        <!-- Perfil (Centro) -->
        <ImageView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:src="@drawable/ic_user"
            android:background="@drawable/bg_circle_white" />

        <!-- Notificaciones -->
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <ImageView
                android:id="@+id/navNotifications"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_notifications"
                app:tint="#000000" />

            <TextView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_alignTop="@id/navNotifications"
                android:layout_alignEnd="@id/navNotifications"
                android:layout_marginTop="-4dp"
                android:layout_marginEnd="-4dp"
                android:background="@drawable/bg_badge_cyan"
                android:backgroundTint="#FF0000"
                android:gravity="center"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

        </RelativeLayout>

    </LinearLayout>

</RelativeLayout>